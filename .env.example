# Anthropic Claude API Key
ANTHROPIC_API_KEY=sk-ant-...

# NewsAPI.org (gratis en https://newsapi.org)
NEWS_API_KEY=your_newsapi_key_here

# Finnhub (gratis en https://finnhub.io — para calendario económico)
FINNHUB_API_KEY=your_finnhub_key_here

# FRED - Federal Reserve Economic Data (gratis en https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_key_here

# Alpha Vantage (gratis en https://www.alphavantage.co/support/#api-key — 25 calls/día)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# SEC EDGAR - Email requerido para User-Agent (política de SEC)
SEC_EDGAR_EMAIL=your_email@example.com

# Puerto del servidor
PORT=3000

# Token secreto para proteger el endpoint de trigger manual
API_SECRET=tu_clave_secreta_aqui
